{
  "name": "mobile-shop-app",
  "version": "0.1.0",
  "description": "Mobile shop CRUD app - devices and customers (Phase 1)",
  "main": "src/main/main.js",
  "scripts": {
    "dev:react": "VITE_CJS_IGNORE_WARNING=true vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "build:react": "vite build",
    "start": "npm run build:react && electron .",
    "package": "npm run build:react && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-reload": "^2.0.0-alpha.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.yourcompany.mobileshopapp",
    "productName": "Mobile Shop Manager",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
